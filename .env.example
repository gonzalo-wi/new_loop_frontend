# Backend origin. In dev it's proxied by Vite; in Docker, nginx proxies /api here.
VITE_API_URL=http://192.168.0.42:8095

# Google Maps JavaScript API key (browser key, restrict by HTTP referrer).
# Used by the truck-tracking map. If empty, the map falls back to a link-out.
VITE_GOOGLE_MAPS_API_KEY=

# Fallback map center when a truck reports no valid GPS fix (defaults to Bs. As.).
VITE_DEFAULT_LAT=-34.6037
VITE_DEFAULT_LNG=-58.3816
